# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
# In production NONE of these live in a file — they come from a secrets manager.

# ── App ──
# Session cookie signing key (HMAC-SHA256). REQUIRED — app refuses to start without it.
# Generate a strong value:  openssl rand -hex 32
SESSION_SECRET=change-me-run-openssl-rand-hex-32

# Port the app listens on (Next.js respects PORT). Default 3000.
PORT=3000

# Log level for structured JSON logs: debug | info | warn | error
LOG_LEVEL=info

# ── Postgres (dev) ──
# Dev DB password — single source of truth. docker-compose reads it for the postgres
# service and for the app's DATABASE_URL. Throwaway; NEVER reuse this value in the cloud.
POSTGRES_PASSWORD=devpassword

# DB connection string for host-based `npm run dev` only (host = localhost).
# The docker-compose.yml stack builds its own URL with host `postgres`.
DATABASE_URL=postgres://taskuser:devpassword@localhost:5432/tasktracker
